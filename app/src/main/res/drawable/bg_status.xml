<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="@color/primaryGreen"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="@color/white"/>

    <!-- Internal padding -->
    <padding
        android:left="6dp"
        android:right="6dp"
        android:top="2dp"
        android:bottom="2dp"/>

</shape>