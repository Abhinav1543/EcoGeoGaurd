<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Expand IoT Sensor Network"
                android:textColor="@color/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPriority"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center"
                android:text="HIGH"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"
                android:background="@color/warningOrange" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PENDING"
                android:textColor="@color/warningOrange"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Category -->
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Technology"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:drawablePadding="4dp"
            android:drawableStart="@drawable/ic_category"
            android:layout_marginBottom="4dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Increase sensor coverage in high-risk villages to improve early warning capabilities."
            android:textColor="@color/textPrimary"
            android:textSize="13sp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="8dp" />

        <!-- Cost and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvCost"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₹25 L"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:drawablePadding="4dp"
                android:drawableStart="@drawable/ic_rupee" />

            <TextView
                android:id="@+id/tvTimeFrame"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="6 months"
                android:textColor="@color/textSecondary"
                android:textSize="12sp"
                android:drawablePadding="4dp"
                 />

        </LinearLayout>

        <!-- AI Confidence -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="92% AI Confidence"
                android:textColor="@color/success"
                android:textSize="11sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/progressConfidence"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="4dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="92"
                android:progressTint="@color/success" />

        </LinearLayout>

        <!-- Date and Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="15 Jan 2026"
                android:textColor="@color/textSecondary"
                android:textSize="10sp"
                android:drawablePadding="4dp"
                android:drawableStart="@drawable/ic_calendar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Approve"
                android:textColor="@color/success"
                android:textSize="11sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Reject"
                android:textColor="@color/dangerRed"
                android:textSize="11sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImplement"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Implement"
                android:textColor="@color/info"
                android:textSize="11sp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>