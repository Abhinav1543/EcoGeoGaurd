<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgLight"
    tools:context=".ui.disaster.ResourceManagementFragment">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryGreen"
        app:title="Resource Management"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@drawable/ic_back"
        app:menu="@menu/menu_resources" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Resource Summary Cards -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 Resource Summary"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvTotalRequests"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primaryGreen"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Requests"
                            android:textColor="@color/textSecondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvPendingRequests"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/warningOrange"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textColor="@color/textSecondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvCompletedToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/success"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completed"
                            android:textColor="@color/textSecondary"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Inventory Status -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📦 Inventory Status"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Food Supply -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_food"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Food Supplies"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvFoodCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2,500 meals"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvFoodStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Good"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_green" />

                    </LinearLayout>

                    <!-- Water Supply -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_water"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Water Supply"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvWaterCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5,000 L"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvWaterStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Good"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_green" />

                    </LinearLayout>

                    <!-- Medical Kits -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_medical"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Medical Kits"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMedicalCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="150 kits"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvMedicalStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Low"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_orange" />

                    </LinearLayout>

                    <!-- Blankets -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/img_37"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Blankets"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvBlanketCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="800 units"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvBlanketStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Good"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_green" />

                    </LinearLayout>

                    <!-- Tents -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_tent"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tents"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvTentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 units"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvTentStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Critical"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_red" />

                    </LinearLayout>

                    <!-- Generators -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/img_36"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Generators"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvGeneratorCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8 units"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvGeneratorStatus"
                            android:layout_width="60dp"
                            android:layout_height="24dp"
                            android:gravity="center"
                            android:text="Good"
                            android:textColor="@color/white"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_status_green" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Personnel Status -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="👥 Personnel Available"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Medical Team -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Medical Team"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvMedicalTeam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12/15 available"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <ProgressBar
                            android:id="@+id/progressMedicalTeam"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="80dp"
                            android:layout_height="4dp"
                            android:max="15"
                            android:progress="12"
                            android:progressTint="@color/success" />

                    </LinearLayout>

                    <!-- Rescue Team -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rescue Team"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvRescueTeam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20/25 available"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <ProgressBar
                            android:id="@+id/progressRescueTeam"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="80dp"
                            android:layout_height="4dp"
                            android:max="25"
                            android:progress="20"
                            android:progressTint="@color/success" />

                    </LinearLayout>

                    <!-- Engineering Team -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Engineering Team"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvEngineeringTeam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5/8 available"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <ProgressBar
                            android:id="@+id/progressEngineeringTeam"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="80dp"
                            android:layout_height="4dp"
                            android:max="8"
                            android:progress="5"
                            android:progressTint="@color/warning" />

                    </LinearLayout>

                    <!-- Logistics Team -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Logistics Team"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvLogisticsTeam"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10/10 available"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp"
                            android:layout_marginEnd="8dp" />

                        <ProgressBar
                            android:id="@+id/progressLogisticsTeam"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="80dp"
                            android:layout_height="4dp"
                            android:max="10"
                            android:progress="10"
                            android:progressTint="@color/success" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Resource Requests Tabs -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Resource Requests"
                android:textColor="@color/textPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <!-- Tab Layout -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:tabGravity="fill"
                app:tabMode="fixed"
                app:tabSelectedTextColor="@color/primaryGreen"
                app:tabTextColor="@color/textSecondary">

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Approved" />

                <com.google.android.material.tabs.TabItem
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Completed" />

            </com.google.android.material.tabs.TabLayout>

            <!-- Requests RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRequests"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewRequest"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="New Request"
                    app:icon="@drawable/ic_add"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAllocate"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Allocate"
                    app:icon="@drawable/ic_allocate"
                    app:iconGravity="textStart" />

            </LinearLayout>

            <!-- Footer -->
            <include layout="@layout/footer_layout" />

        </LinearLayout>

    </ScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CCFFFFFF"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading resources..."
                android:textColor="@color/textPrimary"
                android:textSize="14sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>