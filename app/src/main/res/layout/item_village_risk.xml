<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvVillageName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:text="Himalayan Village"
        android:textColor="@color/textPrimary"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvLandslideRisk"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="HIGH"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_risk_high" />

    <TextView
        android:id="@+id/tvFloodRisk"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="MED"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_risk_medium" />

    <TextView
        android:id="@+id/tvOverallRisk"
        android:layout_width="0dp"
        android:layout_height="24dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="CRIT"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:background="@drawable/bg_risk_critical" />

</LinearLayout>