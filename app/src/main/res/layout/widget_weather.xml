<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/cardBgLight"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Weather Icon -->
        <ImageView
            android:id="@+id/ivWeatherIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_partly_cloud"
            app:tint="@color/primaryGreen"
            android:layout_marginEnd="16dp"/>

        <!-- Weather Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Green Valley Village"
                android:textSize="14sp"
                android:textColor="@color/textPrimary"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Partly Cloudy"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:layout_marginBottom="4dp"/>

            <!-- Weather Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTemperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="28°C"
                    android:textSize="16sp"
                    android:textColor="@color/textPrimary"
                    android:textStyle="bold"/>

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Humidity: 65%"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/tvRainfall"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rain: 12mm"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"/>
            </LinearLayout>


        </LinearLayout>

        <!-- Refresh Button -->
        <ImageButton
            android:id="@+id/btnRefreshWeather"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_refresh"
            android:background="?selectableItemBackgroundBorderless"
            app:tint="@color/primaryGreen"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>